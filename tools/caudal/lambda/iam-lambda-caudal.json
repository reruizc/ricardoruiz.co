{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CaudalLeerMetadata",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::caudal-legislativo/metadata/*"
    },
    {
      "Sid": "CaudalCacheAnalisis",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::caudal-legislativo/analisis-cache/*"
    },
    {
      "Sid": "CaudalLeerGacetas",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": [
        "arn:aws:s3:::caudal-legislativo/gacetas/*",
        "arn:aws:s3:::caudal-legislativo/gacetas-texto/*"
      ]
    }
  ]
}
