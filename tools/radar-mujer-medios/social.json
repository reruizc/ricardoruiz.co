{
  "_doc": "Config de la capa de REDES (Apify) de Radar Mujer. Cada red usa un actor de Apify pay-per-result. queries = términos/hashtags a rastrear. input_template = input del actor con __QUERIES__ y __MAX__ como placeholders. map = rutas (dot-path) del item del actor -> esquema común. OJO: los nombres de campo de input/output VARÍAN por actor — verificar en la primera corrida real con el token (correr 50 items de prueba antes de escalar).",
  "networks": {
    "x": {
      "enabled": true,
      "actor": "kaitoeasyapi/twitter-x-data-tweet-scraper-pay-per-result-cheapest",
      "max_por_query": 120,
      "query_suffix": " lang:es",
      "combined_query": "(feminicidio OR paridad OR lideresa OR \"violencia de género\" OR \"violencia política\" OR \"economía del cuidado\" OR aborto OR \"participación política\" OR ministra OR \"Ministerio de la Igualdad\") Colombia",
      "filtrar_por_lexico": true,
      "input_template": {
        "searchTerms": "__QUERIES__",
        "maxItems": "__MAX_TOTAL__",
        "sort": "Latest"
      },
      "map": {
        "texto": "text",
        "autor": "author/userName",
        "fecha": "createdAt",
        "url": "url",
        "metrica": "likeCount"
      }
    },
    "instagram": {
      "enabled": true,
      "actor": "apify/instagram-hashtag-scraper",
      "max_por_query": 20,
      "hashtags": true,
      "filtrar_por_lexico": true,
      "input_template": {
        "hashtags": "__QUERIES__",
        "resultsLimit": "__MAX_PER__"
      },
      "map": {
        "texto": "caption",
        "autor": "ownerUsername",
        "fecha": "timestamp",
        "url": "url",
        "metrica": "likesCount"
      }
    },
    "tiktok": {
      "enabled": true,
      "actor": "clockworks/tiktok-scraper",
      "max_por_query": 20,
      "hashtags": true,
      "filtrar_por_lexico": true,
      "input_template": {
        "hashtags": "__QUERIES__",
        "resultsPerPage": "__MAX_PER__",
        "proxyCountryCode": "CO"
      },
      "map": {
        "texto": "text",
        "autor": "authorMeta/name",
        "fecha": "createTimeISO",
        "url": "webVideoUrl",
        "metrica": "diggCount"
      }
    }
  },
  "queries_texto": [
    "feminicidio Colombia",
    "violencia de género Colombia",
    "participación política mujeres Colombia",
    "paridad de género Colombia",
    "economía del cuidado Colombia",
    "aborto IVE Colombia",
    "Ministerio de la Igualdad Colombia",
    "lideresas Colombia"
  ],
  "queries_hashtag": [
    "feminicidiocolombia",
    "niunamenos",
    "violenciadegenero",
    "violenciapolitica",
    "economiadelcuidado",
    "abortolegalcolombia",
    "paridaddegenero",
    "mujeresenpolitica"
  ]
}
